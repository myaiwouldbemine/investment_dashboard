#!/usr/bin/env bash
set -euo pipefail

blocked_pattern='^(data/|.*\.(parquet|xlsx|xls|csv)$)'

staged_files=$(git diff --cached --name-only)
if [ -z "${staged_files}" ]; then
  exit 0
fi

blocked_files=$(printf '%s\n' "${staged_files}" | grep -E "${blocked_pattern}" || true)
if [ -n "${blocked_files}" ]; then
  echo "[BLOCKED] Data files are not allowed in Git commits:"
  echo "${blocked_files}" | sed 's/^/ - /'
  echo
  echo "Run this to unstage:"
  echo "  git restore --staged data/ '*.parquet' '*.xlsx' '*.xls' '*.csv'"
  exit 1
fi